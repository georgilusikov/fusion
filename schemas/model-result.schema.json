{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/fusion/model-result.schema.json",
  "title": "ModelResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "label", "backend", "kind", "model", "ok", "answer", "latency_ms",
    "input_tokens", "output_tokens", "total_tokens", "cost_usd", "errors",
    "confidence", "attempts", "returncode", "metadata"
  ],
  "properties": {
    "label": {"type": "string"},
    "backend": {"type": "string"},
    "kind": {"type": "string"},
    "model": {"type": ["string", "null"]},
    "ok": {"type": "boolean"},
    "answer": {"type": "string"},
    "latency_ms": {"type": "integer", "minimum": 0},
    "input_tokens": {"type": ["integer", "null"], "minimum": 0},
    "output_tokens": {"type": ["integer", "null"], "minimum": 0},
    "total_tokens": {"type": ["integer", "null"], "minimum": 0},
    "cost_usd": {"type": ["number", "null"], "minimum": 0},
    "errors": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "attempts": {"type": "integer", "minimum": 1},
    "returncode": {"type": ["integer", "null"]},
    "metadata": {"type": "object"}
  }
}
